generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// Domain enums
// ─────────────────────────────────────────────

enum UnitOfMeasure {
  KG
  PIECE
}

enum LedgerEventType {
  OPENING_STOCK
  RECEIPT
  PRODUCTION
  DISPATCH
  ADJUSTMENT
  DELETION_CLEANUP
}

enum WorkOrderStatus {
  OPEN
  COMPLETED
  CANCELLED
}

enum EmploymentType {
  PERMANENT
  DAILY
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  HOLIDAY
}

enum LeaveType {
  CASUAL
  SICK
  UNPAID
  OTHER
}

enum ProductionFloorEventType {
  ISSUE
  CONSUME
  ADJUSTMENT
}

// ─────────────────────────────────────────────
// Platform / tenancy enums
// ─────────────────────────────────────────────

enum GlobalRole {
  SUPER_ADMIN
  USER
}

enum CompanyRole {
  ADMIN
  MANAGER
  OPERATOR
}

// ─────────────────────────────────────────────
// Platform / tenancy models
// ─────────────────────────────────────────────

model Company {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships             CompanyMembership[]
  rawMaterials            RawMaterial[]
  finishedProducts        FinishedProduct[]
  finishedProductVariants FinishedProductVariant[]
  rawMaterialLedgers      RawMaterialLedger[]
  finishedProductLedgers  FinishedProductLedger[]
  workOrders              WorkOrder[]
  workOrderRawMaterials   WorkOrderRawMaterial[]
  productionEntries       ProductionEntry[]
  productionFloorStocks   ProductionFloorStock[]
  productionFloorLedgers  ProductionFloorLedger[]
  departments             Department[]
  employees               Employee[]
  attendance              Attendance[]
  leaves                  Leave[]
}

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  supabaseUserId String     @unique
  globalRole     GlobalRole @default(USER)
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  memberships CompanyMembership[]
}

model CompanyMembership {
  id        String      @id @default(cuid())
  companyId String
  userId    String
  role      CompanyRole
  createdAt DateTime    @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// Tenant / business models
// ─────────────────────────────────────────────

model RawMaterial {
  id                    String                  @id @default(cuid())
  companyId             String
  company               Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  name                  String
  quantityInStock       Decimal                 @default(0) @db.Decimal(10, 2)
  lastReceivedAt        DateTime?
  lastReceivedQuantity  Decimal?                @db.Decimal(10, 2)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  ledgerEntries         RawMaterialLedger[]
  workOrderRawMaterials WorkOrderRawMaterial[]
  productionFloorStock  ProductionFloorStock?
  productionFloorLedger ProductionFloorLedger[]

  @@unique([companyId, name])
  @@index([companyId])
}

model ProductionFloorStock {
  id              String      @id @default(cuid())
  companyId       String
  company         Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  rawMaterialId   String      @unique
  rawMaterial     RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)
  quantityInStock Decimal     @default(0) @db.Decimal(10, 2)
  lastIssuedAt    DateTime?
  lastConsumedAt  DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([companyId])
}

model ProductionFloorLedger {
  id             String                   @id @default(cuid())
  companyId      String
  company        Company                  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  rawMaterialId  String
  rawMaterial    RawMaterial              @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)
  date           DateTime                 @default(now())
  eventType      ProductionFloorEventType
  openingBalance Decimal                  @db.Decimal(10, 2)
  quantityIn     Decimal                  @db.Decimal(10, 2)
  quantityOut    Decimal                  @db.Decimal(10, 2)
  closingBalance Decimal                  @db.Decimal(10, 2)
  notes          String?
  createdAt      DateTime                 @default(now())

  @@index([companyId])
  @@index([rawMaterialId, date])
}

model FinishedProduct {
  id                     String                   @id @default(cuid())
  companyId              String
  company                Company                  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  name                   String
  unit                   UnitOfMeasure            @default(KG)
  isWaste                Boolean                  @default(false)
  quantityInStock        Decimal                  @default(0) @db.Decimal(10, 2)
  weightPerPiece         Decimal?                 @db.Decimal(10, 3) // Weight in KG. Only set when unit = PIECE and no variants.
  isDeleted              Boolean                  @default(false)
  deletedAt              DateTime?
  lastDispatchedAt       DateTime?
  lastDispatchedQuantity Decimal?                 @db.Decimal(10, 2)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  ledgerEntries          FinishedProductLedger[]
  workOrders             WorkOrder[]
  variants               FinishedProductVariant[]

  @@index([companyId])
  @@index([name])
}

model RawMaterialLedger {
  id             String          @id @default(cuid())
  companyId      String
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  rawMaterialId  String
  rawMaterial    RawMaterial     @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)
  workOrderId    String?
  date           DateTime        @default(now())
  createdAt      DateTime        @default(now())
  eventType      LedgerEventType @default(ADJUSTMENT)
  openingBalance Decimal         @db.Decimal(10, 2)
  quantityIn     Decimal         @db.Decimal(10, 2)
  quantityOut    Decimal         @db.Decimal(10, 2)
  closingBalance Decimal         @db.Decimal(10, 2)
  notes          String?

  @@index([companyId])
}

model FinishedProductLedger {
  id                       String                  @id @default(cuid())
  companyId                String
  company                  Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  finishedProductId        String
  finishedProduct          FinishedProduct         @relation(fields: [finishedProductId], references: [id], onDelete: Cascade)
  finishedProductVariantId String?
  finishedProductVariant   FinishedProductVariant? @relation(fields: [finishedProductVariantId], references: [id])
  workOrderId              String?
  productionEntryId        String?
  date                     DateTime                @default(now())
  createdAt                DateTime                @default(now())
  eventType                LedgerEventType         @default(PRODUCTION)
  openingBalance           Decimal                 @db.Decimal(10, 2)
  quantityProduced         Decimal                 @db.Decimal(10, 2)
  quantityDispatched       Decimal                 @db.Decimal(10, 2)
  closingBalance           Decimal                 @db.Decimal(10, 2)
  notes                    String?

  @@index([companyId])
}

model FinishedProductVariant {
  id                String                  @id @default(cuid())
  companyId         String
  company           Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  finishedProductId String
  finishedProduct   FinishedProduct         @relation(fields: [finishedProductId], references: [id], onDelete: Cascade)
  name              String
  weightPerPiece    Decimal?                @db.Decimal(10, 3) // Weight in KG. Overrides product weightPerPiece when set.
  quantityInStock   Decimal                 @default(0) @db.Decimal(10, 2)
  isDeleted         Boolean                 @default(false)
  deletedAt         DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  ledgerEntries     FinishedProductLedger[]
  workOrders        WorkOrder[]

  @@index([companyId])
}

model WorkOrder {
  id                       String                  @id @default(cuid())
  companyId                String
  company                  Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  workOrderName            String
  finishedProductId        String?
  finishedProduct          FinishedProduct?        @relation(fields: [finishedProductId], references: [id])
  finishedProductVariantId String?
  finishedProductVariant   FinishedProductVariant? @relation(fields: [finishedProductVariantId], references: [id])
  plannedQuantity          Decimal                 @db.Decimal(10, 2)
  status                   WorkOrderStatus         @default(OPEN)
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  completedAt              DateTime?
  rawMaterials             WorkOrderRawMaterial[]
  productionEntries        ProductionEntry[]

  @@index([companyId])
}

model WorkOrderRawMaterial {
  id             String      @id @default(cuid())
  companyId      String
  company        Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  workOrderId    String
  workOrder      WorkOrder   @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  rawMaterialId  String
  rawMaterial    RawMaterial @relation(fields: [rawMaterialId], references: [id])
  quantityIssued Decimal     @default(0) @db.Decimal(10, 2)

  @@unique([workOrderId, rawMaterialId])
  @@index([companyId])
}

model ProductionEntry {
  id               String    @id @default(cuid())
  companyId        String
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  workOrderId      String
  workOrder        WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  entryDate        DateTime  @default(now())
  quantityProduced Decimal   @db.Decimal(10, 2)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([companyId])
}

model Department {
  id        String     @id @default(cuid())
  companyId String
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  employees Employee[]

  @@index([companyId])
}

model Employee {
  id             String         @id @default(cuid())
  companyId      String
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  name           String
  phone          String?
  employmentType EmploymentType
  status         EmployeeStatus @default(ACTIVE)

  // Salary fields — only one will be used based on employmentType
  monthlySalary Decimal? @db.Decimal(10, 2) // PERMANENT only
  dailyWage     Decimal? @db.Decimal(10, 2) // DAILY only

  hireDate     DateTime
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  // Soft delete
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendance Attendance[]
  leaves     Leave[]

  @@index([companyId])
}

model Attendance {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  date   DateTime         @db.Date
  status AttendanceStatus @default(PRESENT)

  checkIn       DateTime? // Full timestamp
  checkOut      DateTime? // Full timestamp
  hoursWorked   Decimal?  @db.Decimal(4, 2)
  overtimeHours Decimal?  @db.Decimal(4, 2)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, date]) // One record per employee per day
  @@index([companyId])
}

model Leave {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  leaveType LeaveType
  startDate DateTime  @db.Date
  endDate   DateTime  @db.Date
  totalDays Int
  reason    String?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}
